# ============================================
# Common Clock Mediatek (5.10 mainline)
# ============================================
CONFIG_COMMON_CLK_MEDIATEK=y
CONFIG_COMMON_CLK_MT6768=y
CONFIG_COMMON_CLK_MT6768_MMSYS=y
CONFIG_COMMON_CLK_MT6768_IMGSYS=y
CONFIG_COMMON_CLK_MT6768_VDECSYS=y
CONFIG_COMMON_CLK_MT6768_VENCSYS=y
CONFIG_COMMON_CLK_MT6768_MFGCFG=y
CONFIG_COMMON_CLK_MT6768_AUDSYS=y

# ============================================
# IOMMU (5.10 mainline)
# ============================================
CONFIG_IOMMU_IO_PGTABLE_LPAE=y
CONFIG_MTK_IOMMU=y

# ============================================
# Android / GKI
# ============================================
CONFIG_ANDROID=y
CONFIG_ANDROID_BINDER_IPC=y
CONFIG_ANDROID_BINDERFS=y
CONFIG_ANDROID_BINDER_DEVICES="binder,hwbinder,vndbinder"
CONFIG_ANDROID_LOW_MEMORY_KILLER=y
CONFIG_ANDROID_LOW_MEMORY_KILLER_AUTODETECT_OOM_ADJ_VALUES=y
CONFIG_ASHMEM=y

# ============================================
# Modules
# ============================================
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y
CONFIG_MODVERSIONS=y
CONFIG_MODULE_SIG=y
CONFIG_MODULE_SIG_FORCE=y
CONFIG_MODULE_SIG_SHA256=y

# ============================================
# 5.10 Mainline Gereksinimleri
# ============================================
CONFIG_ARM64=y
CONFIG_64BIT=y
CONFIG_MMU=y
CONFIG_ARCH_PHYS_ADDR_T_64BIT=y
CONFIG_ZONE_DMA32=y
CONFIG_ARCH_DMA_ADDR_T_64BIT=y
CONFIG_SWIOTLB=y
CONFIG_IOMMU_SUPPORT=y
CONFIG_OF=y
CONFIG_OF_OVERLAY=y
CONFIG_OF_ALL_DTBS=y

# Device Tree
CONFIG_DTC=y
CONFIG_PROC_DEVICETREE=y

# Crypto
CONFIG_CRYPTO=y
CONFIG_CRYPTO_AES=y
CONFIG_CRYPTO_ANSI_CPRNG=y
CONFIG_CRYPTO_SHA256=y
CONFIG_CRYPTO_SHA256_ARM64=y

# Security
CONFIG_SECURITY=y
CONFIG_SECURITY_SELINUX=y
CONFIG_SECURITY_SELINUX_BOOTPARAM=y

# Block
CONFIG_BLOCK=y
CONFIG_BLK_MQ_PCI=y
CONFIG_BLK_MQ_PCIE=y

# SCSI / SATA
CONFIG_SCSI=y
CONFIG_BLK_DEV_SD=y

# MMC
CONFIG_MMC=y
CONFIG_MMC_BLOCK=y
CONFIG_MMC_BLOCK_MINORS=32
CONFIG_MMC_SDHCI=y
CONFIG_MMC_SDHCI_PLTFM=y
CONFIG_MMC_MTK=y

# PHY
CONFIG_PHY_MTK_TPHY=y
CONFIG_PHY_MTK_UFS=y
CONFIG_PHY_MTK_MIPI_DSI=y

# PCI
CONFIG_PCI=y
CONFIG_PCIEPORTBUS=y
CONFIG_PCIE_PME=y

# USB
CONFIG_USB=y
CONFIG_USB_SUPPORT=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_XHCI_MTK=y
CONFIG_USB_EHCI_HCD=y
CONFIG_USB_OHCI_HCD=y
CONFIG_USB_STORAGE=y
CONFIG_USB_UAS=y
CONFIG_USB_GADGET=y
CONFIG_USB_CONFIGFS=y
CONFIG_USB_CONFIGFS_F_FS=y
CONFIG_USB_CONFIGFS_RNDIS=y
CONFIG_USB_CONFIGFS_MASS_STORAGE=y

# RTC
CONFIG_RTC_CLASS=y
CONFIG_RTC_DRV_MT6397=y

# Watchdog
CONFIG_WATCHDOG=y
CONFIG_WATCHDOG_CORE=y
CONFIG_MEDIATEK_WATCHDOG=y

# SPI
CONFIG_SPI=y
CONFIG_SPI_MASTER=y
CONFIG_SPI_MEM=y
CONFIG_SPI_MTK_NOR=y

# I2C
CONFIG_I2C=y
CONFIG_I2C_CHARDEV=y
