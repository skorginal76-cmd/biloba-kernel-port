# PWM
CONFIG_PWM=y
CONFIG_PWM_MTK_DISP=y
CONFIG_PWM_MEDIATEK=y

# GPIO
CONFIG_GPIOLIB=y
CONFIG_GPIO_SYSFS=y
CONFIG_GPIO_MTK=y

# Pinctrl
CONFIG_PINCTRL=y
CONFIG_PINCTRL_MTK=y
CONFIG_PINCTRL_MT6768=y

# Regulator
CONFIG_REGULATOR=y
CONFIG_REGULATOR_FIXED_VOLTAGE=y
CONFIG_REGULATOR_MT6358=y
CONFIG_REGULATOR_MT6370=y

# CLK
CONFIG_HAVE_CLK=y
CONFIG_CLKDEV_LOOKUP=y
CONFIG_COMMON_CLK=y

# Power
CONFIG_POWER_SUPPLY=y
CONFIG_POWER_RESET=y
CONFIG_POWER_RESET_SYSCON=y

# Battery
CONFIG_BATTERY_MTK=y

# Charger
CONFIG_CHARGER_MTK=y

# LED
CONFIG_NEW_LEDS=y
CONFIG_LEDS_CLASS=y
CONFIG_LEDS_MTK=y

# Input
CONFIG_INPUT=y
CONFIG_INPUT_EVDEV=y
CONFIG_INPUT_KEYRESET=y
CONFIG_KEYBOARD_MTK=y
CONFIG_TOUCHSCREEN_MTK=y

# Sound
CONFIG_SOUND=y
CONFIG_SND=y
CONFIG_SND_SOC=y
CONFIG_SND_SOC_MTK=y
CONFIG_SND_SOC_MT6358=y
CONFIG_SND_SOC_MT6370=y

# DMA
CONFIG_DMADEVICES=y
CONFIG_MTK_HSDMA=y
CONFIG_MTK_CQDMA=y

# Mailbox
CONFIG_MAILBOX=y
CONFIG_MTK_CMDQ_MBOX=y

# Remoteproc
CONFIG_REMOTEPROC=y
