# SOC
CONFIG_MTK_INFRACFG=y
CONFIG_MTK_PMIC=y
CONFIG_MTK_SCPSYS=y
CONFIG_MTK_MMSYS=y

# DRM
CONFIG_DRM=y
CONFIG_DRM_MEDIATEK=y
